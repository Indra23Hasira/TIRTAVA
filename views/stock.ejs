<%- include('partials/head', { title: 'Persediaan/Stok' }) %>
<h1 class="text-xl font-bold mb-1">Persediaan / Stok</h1>
<p class="text-slate-500 text-sm mb-6">Ringkasan stok & kartu stok (mutasi masuk/keluar) per produk</p>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
  <div class="card lg:col-span-1">
    <h2 class="font-semibold mb-3">Ringkasan Stok</h2>
    <table class="data-table w-full text-sm">
      <thead><tr><th>Produk</th><th>Stok</th></tr></thead>
      <tbody>
        <% products.forEach(p => { %>
        <tr class="cursor-pointer <%= p.id === selectedId ? 'bg-blue-50' : '' %>" onclick="location.href='/stock?product_id=<%= p.id %>'">
          <td><%= p.name %></td>
          <td class="<%= p.stok <= p.stok_minimum ? 'text-red-600 font-semibold' : '' %>"><%= p.stok %> <%= p.unit %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <div class="card lg:col-span-2">
    <h2 class="font-semibold mb-3">Kartu Stok</h2>
    <table class="data-table w-full">
      <thead><tr><th>Tanggal</th><th>Jenis</th><th>Qty</th><th>Saldo Setelah</th><th>Referensi</th><th>Keterangan</th></tr></thead>
      <tbody>
        <% movements.forEach(m => { %>
        <tr>
          <td><%= m.tanggal %></td>
          <td><span class="badge <%= m.jenis === 'in' ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-600' %>"><%= m.jenis === 'in' ? 'Masuk' : 'Keluar' %></span></td>
          <td><%= m.qty %></td>
          <td><%= m.saldo_setelah %></td>
          <td class="text-xs text-slate-500"><%= m.ref_tipe %></td>
          <td class="text-xs"><%= m.keterangan %></td>
        </tr>
        <% }) %>
        <% if (movements.length === 0) { %><tr><td colspan="6" class="text-center text-slate-400 py-6">Belum ada mutasi.</td></tr><% } %>
      </tbody>
    </table>
  </div>
</div>
<%- include('partials/foot') %>
