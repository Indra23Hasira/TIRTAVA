<%- include('partials/head', { title: 'Supplier' }) %>
<div class="flex justify-between items-center mb-6">
  <div>
    <h1 class="text-xl font-bold">Master Supplier</h1>
    <p class="text-slate-500 text-sm">Pemasok bahan baku dan kemasan</p>
  </div>
  <button onclick="document.getElementById('formNew').classList.toggle('hidden')" class="btn btn-primary">+ Tambah Supplier</button>
</div>

<div id="formNew" class="card mb-6 hidden">
  <form method="POST" action="/suppliers" class="grid grid-cols-2 md:grid-cols-4 gap-3">
    <input name="code" placeholder="Kode (mis. SUP-003)" required class="form-input">
    <input name="name" placeholder="Nama Supplier" required class="form-input">
    <input name="phone" placeholder="No. Telepon" class="form-input">
    <input name="address" placeholder="Alamat" class="form-input">
    <button class="btn btn-primary">Simpan</button>
  </form>
</div>

<div class="card">
  <table class="data-table w-full">
    <thead><tr><th>Kode</th><th>Nama</th><th>Telepon</th><th>Saldo Hutang</th><th></th></tr></thead>
    <tbody>
      <% suppliers.forEach(s => { %>
      <tr>
        <td><%= s.code %></td>
        <td><%= s.name %></td>
        <td><%= s.phone %></td>
        <td class="<%= s.saldo_hutang > 0 ? 'text-red-600 font-semibold' : '' %>">Rp <%= s.saldo_hutang.toLocaleString('id-ID') %></td>
        <td><button onclick="document.getElementById('edit<%= s.id %>').classList.toggle('hidden')" class="btn btn-secondary text-xs">Edit</button></td>
      </tr>
      <tr id="edit<%= s.id %>" class="hidden">
        <td colspan="5" class="bg-slate-50">
          <form method="POST" action="/suppliers/<%= s.id %>/edit" class="flex flex-wrap gap-2 items-end p-3">
            <div>
              <label class="text-xs">Nama</label>
              <input name="name" value="<%= s.name %>" required class="form-input">
            </div>
            <div>
              <label class="text-xs">Telepon</label>
              <input name="phone" value="<%= s.phone || '' %>" class="form-input">
            </div>
            <div>
              <label class="text-xs">Alamat</label>
              <input name="address" value="<%= s.address || '' %>" class="form-input">
            </div>
            <div>
              <label class="text-xs flex items-center gap-1 mt-2">
                <input type="checkbox" name="is_active" value="1" <%= s.is_active ? 'checked' : '' %>> Aktif
              </label>
            </div>
            <button class="btn btn-primary">Simpan Perubahan</button>
          </form>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<%- include('partials/foot') %>
