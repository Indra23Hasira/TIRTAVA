<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Login - Depot ERP</title>
<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="bg-gradient-to-br from-blue-600 to-slate-900 min-h-screen flex items-center justify-center p-4">
  <div class="bg-white rounded-2xl shadow-xl w-full max-w-sm p-8">
    <div class="text-center mb-6">
      <div class="text-4xl mb-2">💧</div>
      <h1 class="text-xl font-bold text-slate-800">Depot ERP</h1>
      <p class="text-sm text-slate-500">Air Galon & Es Kristal — Login</p>
    </div>

    <% if (error) { %>
      <div class="bg-red-50 text-red-700 text-sm px-4 py-2 rounded-lg mb-4"><%= error %></div>
    <% } %>

    <form method="POST" action="/login" class="space-y-4">
      <div>
        <label class="text-sm font-medium text-slate-700">Email</label>
        <input type="email" name="email" required class="form-input mt-1" placeholder="admin@depot.com"
          style="border:1px solid #cbd5e1;border-radius:8px;padding:8px 12px;width:100%;font-size:14px">
      </div>
      <div>
        <label class="text-sm font-medium text-slate-700">Password</label>
        <input type="password" name="password" required class="form-input mt-1" placeholder="••••••••"
          style="border:1px solid #cbd5e1;border-radius:8px;padding:8px 12px;width:100%;font-size:14px">
      </div>
      <input type="hidden" name="device_name" id="device_name">
      <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white py-2.5 rounded-lg font-medium">
        Masuk
      </button>
    </form>

    <p class="text-xs text-slate-400 text-center mt-6">
      Default: <b>admin@depot.com</b> / <b>admin123</b><br>
      Anda bisa login dari beberapa perangkat sekaligus.
    </p>
  </div>

  <script>
    document.getElementById('device_name').value =
      navigator.platform + ' - ' + (navigator.userAgentData?.platform || navigator.userAgent.slice(0,40));
  </script>
</body>
</html>
