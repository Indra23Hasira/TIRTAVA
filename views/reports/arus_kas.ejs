<%- include('../partials/head', { title: 'Arus Kas' }) %>
<h1 class="text-xl font-bold mb-1">Laporan Arus Kas</h1>
<p class="text-slate-500 text-sm mb-6">Periode <%= start %> s/d <%= end %></p>

<%- include('../partials/period_filter', { start, end }) %>

<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
  <div class="card">
    <h2 class="font-semibold mb-2 text-green-700">Kas Masuk</h2>
    <table class="w-full text-sm">
      <% masuk.forEach(r => { %>
      <tr><td class="py-1 capitalize"><%= (r.ref_tipe || 'lainnya').replace('_',' ') %></td><td class="py-1 text-right">Rp <%= Math.round(r.total).toLocaleString('id-ID') %></td></tr>
      <% }) %>
      <tr class="font-bold border-t"><td class="py-2">Total Masuk</td><td class="py-2 text-right">Rp <%= Math.round(totalMasuk).toLocaleString('id-ID') %></td></tr>
    </table>
  </div>
  <div class="card">
    <h2 class="font-semibold mb-2 text-red-700">Kas Keluar</h2>
    <table class="w-full text-sm">
      <% keluar.forEach(r => { %>
      <tr><td class="py-1 capitalize"><%= (r.ref_tipe || 'lainnya').replace('_',' ') %></td><td class="py-1 text-right">Rp <%= Math.round(r.total).toLocaleString('id-ID') %></td></tr>
      <% }) %>
      <tr class="font-bold border-t"><td class="py-2">Total Keluar</td><td class="py-2 text-right">Rp <%= Math.round(totalKeluar).toLocaleString('id-ID') %></td></tr>
    </table>
  </div>
</div>

<div class="card max-w-md mt-4">
  <div class="flex justify-between text-lg font-bold <%= netCash >= 0 ? 'text-green-600' : 'text-red-600' %>">
    <span>Arus Kas Bersih</span><span>Rp <%= Math.round(netCash).toLocaleString('id-ID') %></span>
  </div>
</div>
<%- include('../partials/foot') %>
